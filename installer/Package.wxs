<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v4+ package definition for Lucky.
  Build via scripts/publish-release.ps1 (binds publish output with -b Payload=...).
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <!-- Stable product identity — do not change UpgradeCode across releases. -->
  <Package
      Name="Lucky"
      Manufacturer="Guts444"
      Version="$(var.ProductVersion)"
      UpgradeCode="A7F3C2E1-9B84-4D6A-8E21-5C0F1A2B3D4E"
      Language="1033"
      Scope="perMachine"
      Compressed="yes">

    <SummaryInformation
        Description="Lucky — local-first AI agent harness for Windows"
        Manufacturer="Guts444" />

    <MajorUpgrade
        DowngradeErrorMessage="A newer version of Lucky is already installed. Uninstall it first if you need to install this older build."
        Schedule="afterInstallInitialize" />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="AppIcon.ico" SourceFile="!(bindpath.Installer)\AppIcon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
    <Property Id="ARPHELPLINK" Value="https://github.com/Guts444/Lucky" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/Guts444/Lucky" />
    <Property Id="ARPNOREPAIR" Value="yes" Secure="yes" />

    <Feature Id="MainFeature" Title="Lucky" Level="1" ConfigurableDirectory="INSTALLFOLDER" AllowAbsent="no">
      <!-- Harvest the entire self-contained publish tree. -->
      <Files Directory="INSTALLFOLDER" Include="!(bindpath.Payload)\**" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Lucky" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Lucky" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <Component Id="StartMenuShortcut" Directory="ApplicationProgramsFolder" Guid="B1C2D3E4-F5A6-4789-B012-3456789ABCDE">
      <Shortcut
          Id="StartMenuLucky"
          Name="Lucky"
          Description="Lucky — local-first AI agent harness"
          Target="[INSTALLFOLDER]Lucky.exe"
          WorkingDirectory="INSTALLFOLDER"
          Icon="AppIcon.ico" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
      <RegistryValue
          Root="HKCU"
          Key="Software\Guts444\Lucky"
          Name="StartMenuShortcut"
          Type="integer"
          Value="1"
          KeyPath="yes" />
    </Component>

    <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="C2D3E4F5-A6B7-4890-C123-456789ABCDEF">
      <Shortcut
          Id="DesktopLucky"
          Name="Lucky"
          Description="Lucky — local-first AI agent harness"
          Target="[INSTALLFOLDER]Lucky.exe"
          WorkingDirectory="INSTALLFOLDER"
          Icon="AppIcon.ico" />
      <RegistryValue
          Root="HKCU"
          Key="Software\Guts444\Lucky"
          Name="DesktopShortcut"
          Type="integer"
          Value="1"
          KeyPath="yes" />
    </Component>

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="!(bindpath.Installer)\License.rtf" />
  </Package>
</Wix>
