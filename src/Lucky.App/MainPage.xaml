<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Lucky_App.MainPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    Loaded="Page_Loaded"
    RequestedTheme="Dark"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="CanvasBrush" Color="#101111" />
        <SolidColorBrush x:Key="RailBrush" Color="#CC20252D" />
        <SolidColorBrush x:Key="GlassBrush" Color="#E52A2A2A" />
        <SolidColorBrush x:Key="GlassSoftBrush" Color="#B8252525" />
        <SolidColorBrush x:Key="StrokeBrush" Color="#3A3A3A" />
        <SolidColorBrush x:Key="StrokeSoftBrush" Color="#2B2B2B" />
        <SolidColorBrush x:Key="TextBrush" Color="#F4F4F4" />
        <SolidColorBrush x:Key="MutedBrush" Color="#A6A6A6" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF7A1A" />
        <SolidColorBrush x:Key="BlueAccentBrush" Color="#4EA3FF" />
        <SolidColorBrush x:Key="ComposerBrush" Color="#FF252525" />
        <SolidColorBrush x:Key="ComposerControlBrush" Color="#FF303030" />

        <Style x:Key="RailButtonStyle" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="IconOnlyButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="7" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="ComposerComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="11,3" />
            <Setter Property="CornerRadius" Value="15" />
            <Setter Property="Background" Value="{StaticResource ComposerControlBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ComposerIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconOnlyButtonStyle}">
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="CornerRadius" Value="15" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Background" Value="{StaticResource ComposerControlBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        </Style>

        <Style x:Key="ComposerSendButtonStyle" TargetType="Button" BasedOn="{StaticResource ComposerIconButtonStyle}">
            <Setter Property="Background" Value="#F0F0F0" />
            <Setter Property="Foreground" Value="#171717" />
        </Style>

        <Style x:Key="EmptyFolderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8E8E8E" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="8,18,0,8" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource GlassBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource CanvasBrush}">
        <Grid Visibility="{Binding ChatVisibility}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="298" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Background="{StaticResource RailBrush}"
                BorderBrush="#303743"
                BorderThickness="0,0,1,0">
                <Grid Padding="8,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="6">
                        <Button
                            Command="{Binding NewChatCommand}"
                            Style="{StaticResource RailButtonStyle}"
                            automation:AutomationProperties.Name="New chat">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE710;" FontSize="13" />
                                <TextBlock Text="New chat" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" Margin="0,18,0,8" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Projects" Style="{StaticResource SectionLabelStyle}" />
                            <ListView
                                ItemsSource="{Binding Projects}"
                                SelectedItem="{Binding SelectedProject, Mode=TwoWay}"
                                SelectionMode="Single"
                                Background="Transparent"
                                Padding="0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="8,6" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Glyph="&#xE8F1;" FontSize="13" Foreground="{StaticResource MutedBrush}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Text="{Binding Name}"
                                                Foreground="{StaticResource TextBrush}"
                                                TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <Grid Margin="8,14,8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="History" Foreground="#8E8E8E" />
                                <Button
                                     Grid.Column="1"
                                     Click="ChooseFolder_Click"
                                     ToolTipService.ToolTip="Choose working folder"
                                     automation:AutomationProperties.Name="Choose working folder"
                                     Style="{StaticResource IconOnlyButtonStyle}">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                                </Button>
                            </Grid>

                            <ListView
                                ItemsSource="{Binding Sessions}"
                                SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                                SelectionMode="Single"
                                Background="Transparent"
                                Padding="0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="32,7,8,7" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Text="{Binding Title}"
                                                Foreground="{StaticResource TextBrush}"
                                                FontSize="14"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Text="{Binding Detail}"
                                                Foreground="{StaticResource MutedBrush}"
                                                FontSize="12" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </ScrollViewer>

                    <Button
                        Grid.Row="2"
                        Command="{Binding OpenSettingsCommand}"
                        automation:AutomationProperties.Name="Open settings"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="#354052"
                        BorderThickness="0,1,0,0"
                        Padding="6,12,6,2">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="28" Height="28" Background="#2D9CDB" CornerRadius="14">
                                <TextBlock
                                    Text="{Binding ProfileInitials}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    FontWeight="SemiBold" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding ProfileDisplayName}" Foreground="{StaticResource TextBrush}" FontSize="13" />
                                <TextBlock Text="Local profile" Foreground="{StaticResource MutedBrush}" FontSize="11" />
                            </StackPanel>
                        </Grid>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Background="{StaticResource CanvasBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border BorderBrush="#292929" BorderThickness="0,0,0,1" Padding="18,12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE8A5;" FontSize="14" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock
                                Text="{Binding SelectedSession.Title, FallbackValue=New chat}"
                                Foreground="{StaticResource TextBrush}"
                                FontWeight="SemiBold" />
                            <TextBlock Text="..." Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <StackPanel
                        Visibility="{Binding EmptyStateVisibility}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="760"
                        Margin="24"
                        Spacing="28">
                        <TextBlock
                            Text="{Binding ChatHeading}"
                            Foreground="{StaticResource TextBrush}"
                            TextAlignment="Center"
                            FontSize="28"
                            FontWeight="SemiBold" />
                        <Button
                            Click="ChooseFolder_Click"
                            Style="{StaticResource EmptyFolderButtonStyle}"
                            HorizontalAlignment="Center"
                            ToolTipService.ToolTip="Change working folder"
                            automation:AutomationProperties.Name="Change working folder">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B7;" FontSize="13" />
                                <TextBlock
                                    Text="{Binding ChatSubheading}"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap"
                                    FontSize="14" />
                                <FontIcon Glyph="&#xE70D;" FontSize="10" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <ScrollViewer
                        x:Name="MessageScrollViewer"
                        Visibility="{Binding MessageListVisibility}"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        Loaded="MessageScrollViewer_Loaded"
                        SizeChanged="MessageScrollViewer_SizeChanged"
                        ViewChanged="MessageScrollViewer_ViewChanged"
                        PointerWheelChanged="MessageScrollViewer_PointerWheelChanged">
                        <ItemsControl
                            x:Name="MessageList"
                            ItemsSource="{Binding Messages}"
                            Margin="0,24,0,120"
                            Loaded="MessageList_Loaded"
                            SizeChanged="MessageList_SizeChanged">
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid MaxWidth="940" HorizontalAlignment="Stretch" Margin="0,0,0,24" Padding="24,0">
                                        <Border
                                            MaxWidth="{Binding BubbleMaxWidth}"
                                            HorizontalAlignment="{Binding BubbleAlignment}"
                                            Background="{Binding BubbleBrush}"
                                            BorderBrush="{Binding BubbleBorderBrush}"
                                            BorderThickness="{Binding BubbleBorderThickness}"
                                            CornerRadius="{Binding BubbleCornerRadius}"
                                            Padding="{Binding BubblePadding}">
                                            <StackPanel Spacing="9">
                                                <Grid Visibility="{Binding HeaderVisibility}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Text="{Binding Tone}"
                                                        Foreground="#9CB8FF"
                                                        FontWeight="SemiBold" />
                                                </Grid>
                                                <Expander
                                                    Visibility="{Binding ThinkingVisibility}"
                                                    IsExpanded="{Binding IsThinkingExpanded, Mode=TwoWay}">
                                                    <Expander.Header>
                                                        <Grid MinWidth="140" Height="25">
                                                            <TextBlock
                                                                Text="{Binding ThinkingLabel}"
                                                                Foreground="{StaticResource MutedBrush}"
                                                                FontSize="12" />
                                                            <ProgressBar
                                                                Height="2"
                                                                VerticalAlignment="Bottom"
                                                                IsIndeterminate="{Binding IsThinking}"
                                                                Foreground="{StaticResource TextBrush}" />
                                                        </Grid>
                                                    </Expander.Header>
                                                    <TextBlock
                                                        Text="{Binding ThinkingText}"
                                                        Foreground="{StaticResource MutedBrush}"
                                                        IsTextSelectionEnabled="True"
                                                        TextWrapping="Wrap"
                                                        FontSize="12"
                                                        LineHeight="18" />
                                                </Expander>
                                                <TextBlock
                                                    Text="{Binding DisplayContent}"
                                                    Foreground="{StaticResource TextBrush}"
                                                    IsTextSelectionEnabled="True"
                                                    TextWrapping="Wrap"
                                                    LineHeight="21" />
                                                <TextBlock
                                                    Text="{Binding Timestamp}"
                                                    Foreground="{StaticResource MutedBrush}"
                                                    FontSize="12"
                                                    HorizontalAlignment="{Binding TimestampAlignment}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <Grid Grid.Row="2" Padding="0,0,0,16">
                    <Border
                        MaxWidth="736"
                        HorizontalAlignment="Center"
                        Margin="18,0"
                        Background="{StaticResource ComposerBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="14,12">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox
                                x:Name="InputBox"
                                Text="{Binding MessageInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Ask for follow-up changes (Ctrl+Enter to send)"
                                KeyDown="InputBox_KeyDown"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                MinHeight="48"
                                MaxHeight="160"
                                Padding="4,2"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                BorderThickness="0"
                                Background="Transparent"
                                FocusVisualPrimaryBrush="Transparent"
                                FocusVisualSecondaryBrush="Transparent">
                                <TextBox.Resources>
                                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                </TextBox.Resources>
                            </TextBox>
                            <Grid Grid.Row="1" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox
                                    ItemsSource="{Binding AccessLevels}"
                                    SelectedItem="{Binding SelectedAccessLevel, Mode=TwoWay}"
                                    Foreground="{StaticResource AccentBrush}"
                                    MinWidth="108"
                                    Style="{StaticResource ComposerComboBoxStyle}" />
                                <Border
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource ComposerControlBrush}"
                                    CornerRadius="15"
                                    Padding="10,6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding ContextUsageLabel}" Foreground="{StaticResource MutedBrush}" FontSize="11" />
                                        <ProgressBar Width="64" Height="5" Value="{Binding ContextUsagePercent}" Maximum="100" />
                                        <TextBlock Text="{Binding ContextUsagePercentText}" Foreground="{StaticResource MutedBrush}" FontSize="11" />
                                    </StackPanel>
                                </Border>
                                <ComboBox
                                    Grid.Column="3"
                                    ItemsSource="{Binding ModelOptions}"
                                    SelectedItem="{Binding SelectedModelOption, Mode=TwoWay}"
                                    DisplayMemberPath="Label"
                                    MinWidth="210"
                                    Style="{StaticResource ComposerComboBoxStyle}" />
                                <Button
                                    Grid.Column="4"
                                     Command="{Binding StopCommand}"
                                     IsEnabled="{Binding IsBusy}"
                                     ToolTipService.ToolTip="Stop the current turn"
                                     automation:AutomationProperties.Name="Stop the current turn"
                                     Style="{StaticResource ComposerIconButtonStyle}">
                                    <FontIcon Glyph="&#xE71A;" FontSize="15" />
                                </Button>
                                <Button
                                     Grid.Column="5"
                                     Command="{Binding SendCommand}"
                                     automation:AutomationProperties.Name="Send message"
                                     Style="{StaticResource ComposerSendButtonStyle}">
                                    <FontIcon Glyph="&#xE724;" FontSize="15" />
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Grid Visibility="{Binding SettingsVisibility}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="298" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Background="{StaticResource RailBrush}"
                BorderBrush="#303743"
                BorderThickness="0,0,1,0"
                Padding="8,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="8">
                        <Button
                            Command="{Binding BackToAppCommand}"
                            Style="{StaticResource RailButtonStyle}"
                            automation:AutomationProperties.Name="Back to app">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE72B;" FontSize="13" />
                                <TextBlock Text="Back to app" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="Personal" Style="{StaticResource SectionLabelStyle}" />
                            <Button
                                Tag="General"
                                Click="SettingsSection_Click"
                                Style="{StaticResource RailButtonStyle}"
                                automation:AutomationProperties.Name="Go to General settings">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE713;" FontSize="13" />
                                    <TextBlock Text="General" />
                                </StackPanel>
                            </Button>
                            <Button
                                Tag="Personalization"
                                Click="SettingsSection_Click"
                                Style="{StaticResource RailButtonStyle}"
                                automation:AutomationProperties.Name="Go to Personalization settings">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE7C3;" FontSize="13" />
                                    <TextBlock Text="Personalization" />
                                </StackPanel>
                            </Button>
                            <Button
                                Tag="Memory"
                                Click="SettingsSection_Click"
                                Style="{StaticResource RailButtonStyle}"
                                automation:AutomationProperties.Name="Go to Memory settings">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE8BD;" FontSize="13" />
                                    <TextBlock Text="Memory" />
                                </StackPanel>
                            </Button>

                            <TextBlock Text="Integrations" Style="{StaticResource SectionLabelStyle}" />
                            <Button
                                Tag="Providers"
                                Click="SettingsSection_Click"
                                Style="{StaticResource RailButtonStyle}"
                                automation:AutomationProperties.Name="Go to provider settings">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE8D7;" FontSize="13" />
                                    <TextBlock Text="Providers" />
                                </StackPanel>
                            </Button>
                            <Button
                                Tag="Searxng"
                                Click="SettingsSection_Click"
                                Style="{StaticResource RailButtonStyle}"
                                automation:AutomationProperties.Name="Go to SearXNG settings">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE774;" FontSize="13" />
                                    <TextBlock Text="SearXNG" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <TextBlock
                        Grid.Row="2"
                        Text="Lucky settings"
                        Foreground="{StaticResource MutedBrush}"
                        Margin="8,12,0,0" />
                </Grid>
            </Border>

            <ScrollViewer x:Name="SettingsScrollViewer" Grid.Column="1" Background="{StaticResource CanvasBrush}" Padding="0,44,0,56">
                <StackPanel x:Name="SettingsContent" Width="672" HorizontalAlignment="Center" Spacing="30">
                    <TextBlock x:Name="GeneralSettingsSection" Text="General" Foreground="{StaticResource TextBrush}" FontSize="20" FontWeight="SemiBold" />

                    <StackPanel Spacing="10">
                        <TextBlock x:Name="ProviderSettingsSection" Text="Providers" Foreground="{StaticResource TextBrush}" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="Connect accounts and configure API or local endpoints here. Choose the active model from the chat composer." Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />

                        <TextBlock Text="Subscription accounts" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid Padding="14" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="OpenAI OAuth (ChatGPT)" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                                        <TextBlock Text="Browser sign-in for Codex models included with an eligible ChatGPT plan" Style="{StaticResource MutedTextStyle}" />
                                        <TextBlock Text="{Binding CodexConnectionStatus}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" MaxWidth="430" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Content="Connect" Click="ConnectChatGpt_Click" />
                                        <Button Content="Disconnect" Command="{Binding DisconnectCodexCommand}" IsEnabled="{Binding IsCodexConnected}" />
                                    </StackPanel>
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource StrokeSoftBrush}" />
                                <Grid Padding="12" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Lucky protects this sign-in with Windows DPAPI and does not reuse Codex CLI credentials." Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Command="{Binding RefreshCodexSubscriptionCommand}" Content="Refresh account models" IsEnabled="{Binding IsCodexConnected}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="API &amp; local providers" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" Margin="0,12,0,0" />
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid Padding="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="240" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Provider" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Editing a provider never switches the active chat model" Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding ProviderSetupOptions}" SelectedItem="{Binding SelectedProviderSetup, Mode=TwoWay}" SelectionChanged="ProviderSetup_SelectionChanged" />
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource StrokeSoftBrush}" />
                                <Grid Padding="12" ColumnSpacing="16" Visibility="{Binding ProviderEndpointVisibility}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="240" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Endpoint" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1" Text="{Binding ProviderEndpoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsProviderEndpointEditable}" />
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource StrokeSoftBrush}" />
                                <Grid Padding="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="240" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Input context" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Uses provider-reported input context after a response, with a local estimate beforehand" Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                    <NumberBox Grid.Column="1" Value="{Binding ContextWindowTokens, Mode=TwoWay}" IsEnabled="{Binding IsContextWindowEditable}" Minimum="1024" Maximum="10000000" SpinButtonPlacementMode="Compact" />
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource StrokeSoftBrush}" />
                                <Grid Padding="12" ColumnSpacing="16" Visibility="{Binding ApiKeyVisibility}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="240" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="API key" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                    <PasswordBox Grid.Column="1" x:Name="ApiKeyBox" PlaceholderText="Leave blank to keep saved key" PasswordChanged="ApiKeyBox_PasswordChanged" />
                                </Grid>
                                <Grid Padding="12" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Command="{Binding RefreshModelsCommand}" Content="Refresh models" />
                                    <Button Grid.Column="1" Command="{Binding SaveSettingsCommand}" Content="Save provider" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <TextBlock Text="Permissions" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid Padding="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="240" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Default permissions" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Choose how much Lucky may do without adding future tools" Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding AccessLevels}" SelectedItem="{Binding SelectedAccessLevel, Mode=TwoWay}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <TextBlock Text="Subagents" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid Padding="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Enable subagents" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Allow bounded child agents during a turn" Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding SubagentsEnabled, Mode=TwoWay}" />
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource StrokeSoftBrush}" />
                                <Grid Padding="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Auto-delegate" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Let Lucky delegate when parallel work helps" Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding AutoDelegateEnabled, Mode=TwoWay}" />
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource StrokeSoftBrush}" />
                                <Grid Padding="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Max parallel" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                    <NumberBox Grid.Column="1" Value="{Binding MaxParallelSubagents, Mode=TwoWay}" Minimum="1" Maximum="12" SpinButtonPlacementMode="Compact" />
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource StrokeSoftBrush}" />
                                <Grid Padding="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Max per turn" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                    <NumberBox Grid.Column="1" Value="{Binding MaxSubagentsPerTurn, Mode=TwoWay}" Minimum="0" Maximum="12" SpinButtonPlacementMode="Compact" />
                                </Grid>
                                <Grid Padding="12" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text=".lucky\agents\*.json and LocalAppData\Lucky\agents\*.json" Style="{StaticResource MutedTextStyle}" />
                                    <Button Grid.Column="1" Command="{Binding SaveSettingsCommand}" Content="Save" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <TextBlock x:Name="PersonalizationSettingsSection" Text="Personalization" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                        <Border Style="{StaticResource SettingsCardStyle}" Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Custom instructions" Foreground="{StaticResource TextBrush}" />
                                <TextBox
                                    Text="{Binding Persona, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Add Lucky's persona and standing instructions..."
                                    AcceptsReturn="True"
                                    TextWrapping="Wrap"
                                    MinHeight="190" />
                                <Button Command="{Binding SaveSettingsCommand}" HorizontalAlignment="Right" Content="Save" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <TextBlock x:Name="MemorySettingsSection" Text="Memory" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                        <TextBlock Text="Hermes-style split memory: USER profile facts stay compact, while MEMORY stores durable project/session notes." Style="{StaticResource MutedTextStyle}" />
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid Padding="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Enable memories" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Generate new memories from explicit and preference-like chats" Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding MemoriesEnabled, Mode=TwoWay}" />
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource StrokeSoftBrush}" />
                                <Grid Padding="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding UserProfileUsageLabel}" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Identity, preferences, and long-lived user facts" Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Command="{Binding DisableSelectedMemoryCommand}" Content="Disable latest" />
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource StrokeSoftBrush}" />
                                <Grid Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="{Binding MemoryUsageLabel}" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Project notes and durable conversation facts" Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <TextBlock x:Name="SearxngSettingsSection" Text="SearXNG" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid Padding="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="240" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Search endpoint" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1" Text="{Binding SearxngUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource StrokeSoftBrush}" />
                                <Grid Padding="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Auto web search" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding AutoWebSearch, Mode=TwoWay}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <TextBlock Text="Trusted page reader" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                        <TextBlock Text="Lets Lucky read static text from only the domains you explicitly trust. It does not carry browser cookies, logins, or form interactions." Style="{StaticResource MutedTextStyle}" />
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid Padding="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Enable page reading" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Exposes the web_open tool only when at least one trusted domain is configured" Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding BrowserEnabled, Mode=TwoWay}" />
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource StrokeSoftBrush}" />
                                <Grid Padding="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="300" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Trusted domains" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Comma-separated, for example docs.microsoft.com, modelcontextprotocol.io" Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Text="{Binding BrowserAllowedDomains, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="example.com, docs.example.com" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <TextBlock Text="MCP servers" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                        <TextBlock Text="MCP servers are opt-in local stdio processes. Lucky starts them only during a Full access turn, discovers their tools, shows each call in the trace, and stops them when the turn ends. Launch configuration is protected for this Windows user when saved." Style="{StaticResource MutedTextStyle}" />
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel Spacing="0">
                                <Grid Padding="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Enable MCP tools" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="MCP capabilities can be powerful; keep Full access deliberate" Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding McpEnabled, Mode=TwoWay}" />
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource StrokeSoftBrush}" />
                                <StackPanel Padding="12" Spacing="8">
                                    <TextBlock Text="Add a local stdio server" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding McpServerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Display name" />
                                        <TextBox Grid.Column="1" Text="{Binding McpServerCommand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Command, for example npx" />
                                    </Grid>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="180" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding McpServerArguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Arguments; quote paths with spaces" />
                                        <TextBox Grid.Column="1" Text="{Binding McpServerWorkingDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Optional working folder" />
                                    </Grid>
                                    <Button Command="{Binding AddMcpServerCommand}" Content="Add server" HorizontalAlignment="Left" />
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding McpServers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Padding="12" Spacing="5">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Detail}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Command="{Binding DataContext.RemoveMcpServerCommand, ElementName=RootPage}" CommandParameter="{Binding}" Content="Remove" />
                                                </Grid>
                                                <Rectangle Height="1" Fill="{StaticResource StrokeSoftBrush}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <TextBlock Text="Code execution sandbox" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                        <TextBlock Text="Optional Docker-only execution for disposable code checks. Lucky never pulls an image automatically, and this is separate from the unsandboxed Full access PowerShell runner." Style="{StaticResource MutedTextStyle}" />
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid Padding="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Enable Docker code sandbox" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Exposed only in Full access after you choose an already-local image" Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding SandboxEnabled, Mode=TwoWay}" />
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource StrokeSoftBrush}" />
                                <Grid Padding="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="300" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Local Linux Docker image" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="For example local/lucky-sandbox:latest. Build or load it yourself; missing images fail without a pull." Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Text="{Binding SandboxImage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="local/lucky-sandbox:latest" />
                                </Grid>
                                <Rectangle Height="1" Fill="{StaticResource StrokeSoftBrush}" />
                                <Grid Padding="12" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Max seconds" Foreground="{StaticResource TextBrush}" />
                                        <NumberBox Value="{Binding SandboxTimeoutSeconds, Mode=TwoWay}" Minimum="5" Maximum="120" SpinButtonPlacementMode="Compact" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="Memory MiB" Foreground="{StaticResource TextBrush}" />
                                        <NumberBox Value="{Binding SandboxMemoryMiB, Mode=TwoWay}" Minimum="64" Maximum="2048" SpinButtonPlacementMode="Compact" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="4">
                                        <TextBlock Text="CPU cores" Foreground="{StaticResource TextBrush}" />
                                        <NumberBox Value="{Binding SandboxCpuLimit, Mode=TwoWay}" Minimum="0.25" Maximum="2" SmallChange="0.25" SpinButtonPlacementMode="Compact" />
                                    </StackPanel>
                                </Grid>
                                <Grid Padding="12,0,12,12" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="PID limit" Foreground="{StaticResource TextBrush}" />
                                        <NumberBox Value="{Binding SandboxPidsLimit, Mode=TwoWay}" Minimum="16" Maximum="256" SpinButtonPlacementMode="Compact" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="Scratch MiB" Foreground="{StaticResource TextBrush}" />
                                        <NumberBox Value="{Binding SandboxScratchMiB, Mode=TwoWay}" Minimum="16" Maximum="512" SpinButtonPlacementMode="Compact" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="No host folders are mounted. Network is disabled; root is read-only; capabilities are dropped; the process runs as a non-root UID." Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" VerticalAlignment="Bottom" />
                                </Grid>
                                <Grid Padding="12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Docker Desktop's local Windows named pipe must be running. A container is removed after each run; timeout/cancel also requests forced removal." Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Command="{Binding SaveSettingsCommand}" Content="Save settings" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
